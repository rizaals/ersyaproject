# ─────────────────────────────────────────────
# LandingForge — Environment Variables
# Salin file ini menjadi .env.local untuk development
# JANGAN commit .env.local ke repository
# ─────────────────────────────────────────────

# ── APP ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LandingForge

# ── DATABASE ─────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/landingforge

# ── NEXTAUTH ─────────────────────────────────
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ── MIDTRANS ─────────────────────────────────
# Ambil dari: https://dashboard.midtrans.com > Settings > Access Keys
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Ganti ke 'production' saat live
MIDTRANS_IS_PRODUCTION=false

# ── CLOUDINARY ───────────────────────────────
# Ambil dari: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# ── RESEND (Email) ────────────────────────────
# Ambil dari: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Alamat pengirim email — harus verified domain di Resend
RESEND_FROM_EMAIL=noreply@landingforge.id

# ── FONNTE (WhatsApp) ─────────────────────────
# Ambil dari: https://fonnte.com
FONNTE_TOKEN=your_fonnte_token_here
# Nomor WhatsApp superadmin untuk notifikasi order baru
ADMIN_WHATSAPP_NUMBER=628xxxxxxxxxx

# ── SUBDOMAIN SERVER ─────────────────────────
# VPS yang menjalankan Nginx wildcard untuk *.domain.com
SUBDOMAIN_SERVER_URL=https://subdomain-api.landingforge.id
SUBDOMAIN_SERVER_SECRET=your_server_secret_here
# Domain wildcard untuk LP customer
NEXT_PUBLIC_PREVIEW_DOMAIN=landingforge.id

# ── CLAUDE API (Template Generator Mode B) ───
# Ambil dari: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── UPLOAD ───────────────────────────────────
# Maksimum ukuran upload file (bytes) — default 50MB
MAX_UPLOAD_SIZE=52428800
# Tipe file yang diizinkan customer upload
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,application/zip
